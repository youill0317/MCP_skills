{
  "name": "mcp-skills-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "MCP bridge that runs skill-like workflows using SKILL.md folders.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "migrate:skills-frontmatter": "tsx src/cli/migrate-skills-frontmatter.ts",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.8.7",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
